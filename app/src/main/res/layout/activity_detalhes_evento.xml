<?xml version="1.0" encoding="utf-8"?>

<!-- Tela responsável pela exibição dos detalhes de um evento -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <!-- Exibe o nome do evento selecionado -->
    <TextView
        android:id="@+id/txtNomeEvento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome Evento"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#6200EE"
        android:layout_marginBottom="16dp"/>

    <!-- Exibe a data do evento -->
    <TextView
        android:id="@+id/txtDataEvento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Data"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <!-- Exibe o local do evento -->
    <TextView
        android:id="@+id/txtLocalEvento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Local"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"/>

    <!-- Título da seção de convidados -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Convidados"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <!-- Lista que exibe os convidados do evento -->
    <ListView
        android:id="@+id/listViewConvidadosEvento"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>
